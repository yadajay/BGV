@page
@model RCD.AuthAPI.Pages.Manage.IndexModel
@{
    ViewData["Title"] = "Profile";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h4 class="card-title mb-4">Your Profile</h4>

                @if (!string.IsNullOrEmpty(Model.StatusMessage))
                {
                    <div class="alert alert-success">@Model.StatusMessage</div>
                }

                <dl class="row mb-4">
                    <dt class="col-sm-4 text-muted">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4 text-muted">Roles</dt>
                    <dd class="col-sm-8">
                        @if (Model.Roles.Any())
                        {
                            foreach (var role in Model.Roles)
                            {
                                <span class="badge bg-secondary me-1">@role</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">No roles assigned</span>
                        }
                    </dd>

                    <dt class="col-sm-4 text-muted">Status</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactive</span>
                        }
                    </dd>
                </dl>

                <div class="d-flex gap-2">
                    <a asp-page="/Manage/ChangePassword" class="btn btn-outline-primary">
                        Change password
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
