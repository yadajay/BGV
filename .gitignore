## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
Log/
Logs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
*.VC.db
*.VC.opendb

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# CoreCLR trace and dump files
*.htrace
*.jtrace
*.dump

# Windows image transitions
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon

# Docker
.dockerignore

# Node/NPM (for RCD.Web scripts/libman)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# NuGet Packages
*.nupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/

# Entity Framework Core
*.design.time.lock.json

# Secret / Environment files
.env
.env.*
! .env.example
secrets.json

# Testing
TestResults/

# Publish
publish/

# Tooling
.tools/
.config/dotnet-tools.json

# Rider
.idea/
*.sln.iml

# User-specific project settings
*.user