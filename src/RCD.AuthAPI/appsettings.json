{
  "AllowedHosts": "*",

  // Base URL of this auth server. Used when building links in emails (password reset, email verify).
  // Override via environment variable: AppBaseUrl=https://auth.yourdomain.com
  "AppBaseUrl": "",

  // Override via environment variable: ConnectionStrings__DefaultConnection=Host=...
  "ConnectionStrings": {
    "DefaultConnection": "",
    "Redis": ""
  },

  // Client redirect URIs and secrets for all registered OIDC clients.
  // URIs: update to match your deployed environment.
  // Secrets: NEVER commit real values — always set via environment variables in production:
  //   ClientSettings__NextJsClientSecret=<secret>
  //   ClientSettings__MvcClientSecret=<secret>
  //   ClientSettings__ServiceClientSecret=<secret>
  "ClientSettings": {
    "AllowedOrigins": [],
    "SpaRedirectUri": "",
    "SpaPostLogoutUri": "",
    "NextJsRedirectUri": "",
    "NextJsPostLogoutUri": "",
    "MvcRedirectUri": "",
    "MvcPostLogoutUri": "",
    "SwaggerRedirectUri": "",
    "NextJsClientSecret": "",
    "MvcClientSecret": "",
    "ServiceClientSecret": ""
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://seq:80" }
      }
    ]
  }
}
