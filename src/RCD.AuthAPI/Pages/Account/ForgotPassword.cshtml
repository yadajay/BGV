@page
@model RCD.AuthAPI.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col auth-card">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-md-5">
                <h4 class="card-title mb-1">Reset your password</h4>
                <p class="text-muted small mb-4">
                    Enter your email and we'll send you a link to reset your password.
                </p>

                @if (Model.EmailSent)
                {
                    <div class="alert alert-success">
                        If that email is registered, a reset link has been sent. Check your inbox.
                    </div>
                    <a asp-page="/Account/Login" class="btn btn-outline-primary w-100 mt-2">Back to sign in</a>
                }
                else
                {
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label">Email</label>
                            <input asp-for="Input.Email" class="form-control" autocomplete="email"
                                   autofocus placeholder="you@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Send reset link</button>
                        <a asp-page="/Account/Login" class="btn btn-link w-100 mt-1 text-decoration-none">
                            Back to sign in
                        </a>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
