{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to .NET Core in Docker",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickRemoteProcess}",
            "justMyCode": false,
            "sourceFileMap": {
                "/src": "${workspaceFolder}/src"
            },
            "pipeTransport": {
                "pipeProgram": "docker",
                "pipeArgs": ["exec", "-i", "rcd-authapi", "bash", "-lc"],
                "debuggerPath": "/vsdbg/vsdbg",
                "pipeCwd": "${workspaceFolder}"
            }
        }
    ]
}