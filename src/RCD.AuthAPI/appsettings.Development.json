{
  // Development-only overrides. This file is excluded from production deployments.
  // Secrets here are for local development only — use environment variables in any shared environment.
  //
  // Environment variable naming: replace ':' with '__' (double underscore), e.g.:
  //   ClientSettings:NextJsClientSecret  →  ClientSettings__NextJsClientSecret
  //   ConnectionStrings:DefaultConnection →  ConnectionStrings__DefaultConnection

  "AppBaseUrl": "https://localhost:7001",

  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=RCD_db;Username=RCD_user;Password=RCD_password",
    "Redis": "localhost:6379"
  },

  "ClientSettings": {
    "AllowedOrigins": [
      "https://localhost:3000",
      "https://localhost:3001",
      "https://localhost:5001"
    ],
    "SpaRedirectUri":     "https://localhost:3000/callback",
    "SpaPostLogoutUri":   "https://localhost:3000/",
    "NextJsRedirectUri":  "https://localhost:3001/api/auth/callback",
    "NextJsPostLogoutUri":"https://localhost:3001/",
    "MvcRedirectUri":     "https://localhost:5001/signin-oidc",
    "MvcPostLogoutUri":   "https://localhost:5001/signout-callback-oidc",
    "SwaggerRedirectUri": "https://localhost:7001/swagger/oauth2-redirect.html",

    // Dev secrets — override with strong values in any shared or production environment
    "NextJsClientSecret":  "nextjs-dev-secret",
    "MvcClientSecret":     "mvc-dev-secret",
    "ServiceClientSecret": "service-dev-secret"
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "System": "Information"
      }
    }
  }
}
